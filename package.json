{
  "name": "clubrogue",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node scripts/prisma-generate.cjs && node scripts/run-prisma.cjs migrate deploy && next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "node scripts/prisma-generate.cjs",
    "db:migrate": "node scripts/run-prisma.cjs migrate dev",
    "db:push": "node scripts/run-prisma.cjs db push",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "node scripts/prisma-generate.cjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "framer-motion": "^12.42.2",
    "jose": "^6.2.3",
    "next": "14.2.5",
    "pg": "^8.22.0",
    "razorpay": "^2.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
